# ==================== 版本控制 ====================
.git
.gitignore
.gitattributes

# ==================== Python 缓存 ====================
__pycache__
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/

# ==================== IDE ====================
.idea/
.vscode/
*.swp
*.swo

# ==================== 文档 ====================
README.md
docs/
stage/

# ==================== 数据（运行时生成）====================
backend/uploads/*
backend/data/*.db
!backend/data/.gitkeep

# ==================== 后端缓存（不需要打包）====================
backend/__pycache__/
backend/*.pyc

# ==================== 前端缓存（不需要打包，源码由 Dockerfile 显式 COPY）====================
frontend/node_modules/

# ==================== 实验代码（不需要打包）====================
src/experiment/
src/shared/
src/data/

# ==================== OS ====================
.DS_Store
Thumbs.db
